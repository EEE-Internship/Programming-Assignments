To prove curl of H is perpendicular to H*/ 
#include <stdio.h>
int main()
{
    int Hx=1;
    int Cx=2;
    int dot product= Hx*Cx;
    printf("dot product,%d");
    if (dot product==0)
        printf("curl is perpendicular to H");
    else
        printf("curl is not perpendicular to H");
    return 0;
}

