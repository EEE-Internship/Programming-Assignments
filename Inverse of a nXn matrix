  //Program to calculate the nXn matrix


#include <stdio.h>
int main()
{
    int a[3][3];
    int i, j;
    float determinant = 0;    // determinant value is initially zero
    printf("Enter the 3X3 elements of matrix : ");
    for(i = 0; i < 3; i++)
    {
        for(j = 0; j < 3; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }
    printf("\nThe matrix is\n");       // displaying the entered matrix
    for(i = 0; i < 3; i++)
    {
        printf("\n");

        for(j = 0; j < 3; j++)
        {
            printf("%d\t", a[i][j]);
        }
    }
    for(i = 0; i < 3; i++)
    {
        determinant = determinant +  (a[0][i] * (a[1][(i+1)%3] * a[2][(i+2)%3]- a[1][(i+2)%3] * a[2][(i+1)%3]));
    }
    if(determinant == 0)     // if determinant is zero inverse is not possible
    {
        printf("\n\Inverse does not exist:\n");
        return 0;
    }
    printf("\n\nInverse of matrix is :\n\n");   // now finding inverse matrix
    for(i = 0; i < 3; i++)
    {
        for(j = 0; j < 3; j++)
        {
            // calculating co factors and dividing by determinant
            printf("%0.2f\t",
                  ((a[(j+1)%3][(i+1)%3] * a[(j+2)%3][(i+2)%3]) - (a[(j+1)%3][(i+2)%3] * a[(j+2)%3][(i+1)%3]))
 / determinant);              // calculating co factors and dividing by determinant
        }
        printf("\n");
    }
    return 0;
}
