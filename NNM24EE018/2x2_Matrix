#include <stdio.h>

void main()
{
    float a,b,c,d,det;

    printf("Enter the elements of the 2x2 matrix:\n");
    scanf("%f%f",&a,&b);
    scanf("%f%f",&c,&d);

    det=(a*d)-(b*c);

    if(det == 0)
    {
        printf("Inverse does not exist because determinant is zero.\n");
    }
    else
    {
        printf("\nDeterminant =%.2f\n",det);

        printf("\nInverse Matrix:\n");
        printf("%.2f\t%.2f\n",d/det,-b/det);
        printf("%.2f\t%.2f\n",-c/det,a/det);
    }
}

