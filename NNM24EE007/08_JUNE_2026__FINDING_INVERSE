/*this program enables a user to find the inverse of a square matrix using Gauss-Jordan method*/

#include <stdio.h>//includes standard i/o functions like printf(), scanf(), etc

int main()//main function where program execution starts
{
    int n, i, j, k;//n is the order of the matrix; i,j,k are the loop variables
    float a[20][40], ratio;//matrix array and ratio used during row operations

    printf("enter the order of the matrix: ");//prints the order of the matrix
    scanf("%d", &n);//reads the order of the square matrix

    printf("enter the elements of the matrix:\n");//input the matrix elements
    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
        {
            scanf("%f", &a[i][j]); //this line store matrix elements
        }
    }
    //creating the augmented matrix [A | I]
    for(i = 0; i < n; i++)
    {
        for(j = n; j < 2 * n; j++)
        {
            if(j == i + n)
                a[i][j]=1;//placing 1 on diagonal of identity matrix
            else
                a[i][j]=0;//placing 0 elsewhere
        }
    }

    //perform Gauss-Jordan elimination
    for(i = 0;i < n;i++)
    {
        //check if pivot element is zero
        if(a[i][i]==0)
        {
            printf("Inverse does not exist.\n");
            return 0;//stop program if inverse cannot be found
        }

        float pivot = a[i][i]; //store pivot element

        //divide entire row by pivot to make pivot=1
        for(j = 0;j<2*n;j++)
        {
            a[i][j] = a[i][j] / pivot;
        }

        //make all other elements in pivot column zero
        for(k = 0; k < n; k++)
        {
            if(k != i) //skip current pivot row
            {
                ratio = a[k][i]; //element to eliminate

                for(j = 0; j < 2 * n; j++)
                {
                    a[k][j] = a[k][j] - ratio * a[i][j];
                }
            }
        }
    }

    printf("\nInverse Matrix:\n");

    //display inverse matrix
    for(i = 0; i < n; i++)
    {
        for(j = n; j < 2 * n; j++)
        {
            printf("%.2f\t", a[i][j]); //print inverse matrix elements
        }
        printf("\n"); //move to next row
    }

    return 0; //successful program termination
}
